# .standards.yml — Project standards configuration
# Generated by coding-standards setup.sh
# Docs: https://coding-standards.c65llc.com/guides/customization/

# Schema version (required)
version: 1

# Languages detected in this project
# Auto-detected during setup; edit to add/remove
languages:
  - python
  - typescript

# AI agents to configure
# Available: claude-code, cursor, copilot, gemini, codex, aider
agents:
  - claude-code
  - cursor
  - copilot

# Project role — determines which role block is included
# Options: service, library, app, data-pipeline
role: service

# Coverage thresholds
coverage:
  minimum: 95    # Overall minimum (%)
  domain: 100    # Domain layer minimum (%)

# Architecture enforcement
# Options: clean (Clean Architecture enforced), none (no architecture constraints)
architecture: clean

# Security strictness
# strict: P0 and P1 block merge
# moderate: P0 blocks merge, P1 warns
# permissive: all security issues are warnings
security: strict
