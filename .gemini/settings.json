{
  "checkpointing": true,
  "terminalPolicy": "auto",
  "defaultModel": "gemini-1.5-pro",
  "mcpServers": {
    "gcp-tooling": {
      "command": "gcloud",
      "args": ["components", "mcp-server"],
      "trust": true
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "${POSTGRES_MCP_DATABASE_URL}"],
      "trust": true
    }
  }
}
