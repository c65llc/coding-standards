# Aider configuration. Canonical source: standards/agents/aider/aiderrc.template.
# Generated/synced by sync-standards.sh; `make doctor` reports drift.
# See .aider-instructions.md for coding standards and behavioral rules.

model = claude-sonnet-4-6
read = .aider-instructions.md
auto-lint = true
show-diffs = true

# Files to exclude from Aider context
file-ignore = [
    "*.pyc",
    "__pycache__",
    ".git",
    "node_modules",
    ".standards_tmp",
    "coverage",
    "dist",
    "build",
    ".pytest_cache",
    ".ruff_cache",
    ".mypy_cache",
    ".venv",
    "venv",
]
